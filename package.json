{
  "name": "dorm",
  "version": "0.0.1",
  "description": "DormDAO - University crypto fund management platform",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "export": "expo export -p web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "detox build-framework-cache && detox build-framework-cache ios.sim.debug && detox test e2e --configuration ios.sim.debug --cleanup",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "dev": "expo start",
    "prepare": "husky install",
    "supabase": "supabase",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:push": "supabase db push",
    "supabase:reset": "supabase db reset",
    "supabase:functions:deploy": "supabase functions deploy"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.21.0",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.26",
    "@supabase/supabase-js": "^2.38.9",
    "@tanstack/react-query": "^5.28.0",
    "expo": "^50.0.0",
    "expo-auth-session": "^5.2.1",
    "expo-constants": "^15.4.5",
    "expo-crypto": "^12.7.1",
    "expo-dev-client": "^3.3.11",
    "expo-haptics": "^12.7.1",
    "expo-linking": "^6.2.2",
    "expo-notifications": "^0.27.7",
    "expo-router": "^3.4.11",
    "expo-secure-store": "^12.7.1",
    "expo-splash-screen": "^0.26.5",
    "expo-status-bar": "^1.11.1",
    "expo-web-browser": "^12.7.2",
    "nativewind": "^2.0.11",
    "react": "^18.2.0",
    "react-dom": "18.2.0",
    "react-native": "^0.73.0",
    "react-native-gesture-handler": "^2.14.1",
    "react-native-reanimated": "^3.6.1",
    "react-native-safe-area-context": "^4.8.2",
    "react-native-screens": "^3.27.0",
    "react-native-web": "^0.19.11",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.22.0",
    "@testing-library/react-native": "^11.5.4",
    "react-test-renderer": "18.2.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-native": "^4.1.0",
    "husky": "^8.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^50.0.0",
    "typescript": "^5.3.3",
    "tailwindcss": "^3.4.1"
  },
  "private": true
}
